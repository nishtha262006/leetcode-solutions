//LeetCode 1249
Minimum Remove To Make valid Parentheses
Difficulty - Medium

Approach:
Approach:
1. Traverse the string from left to right.
2. Store the indices of '(' in a stack.
3. When ')' is found:
   - If the stack is not empty, match it with the top '('.
   - Otherwise, mark this ')' for removal.
4. After traversal, any '(' left in the stack are unmatched,
   so mark them for removal as well.
5. Build the final string by skipping all marked indices.

Time Complexity: O(n)
Space Complexity: O(n)
//
class Solution {
public:
    string minRemoveToMakeValid(string s) {
        stack<int>st;//create stack to store indices of unmatched (

        vector<bool>remove(s.size(),false);// create remove array

        for(int i = 0;i<s.size();i++){//visit very character
            if(s[i] =='('){//opening bracket->store its position

                st.push(i);// push the opening bracket into the stack
            }
            else if (s[i] ==')'){//check whether a matching opening brackets exists

                if(!st.empty()){//if found pop the opening bracket
                    st.pop();//pair formed
                }
                else{// no match found
                    remove[i] = true; // remove the (
                }
            }
        }
        while(!st.empty()){//any opening bracket left in stack is unmatched
            remove[st.top()]= true;//remove it
            st.pop();//pop it
        }
        string ans ="";
        for(int i =0;i<s.size();i++){//traverse again

            if(!remove[i]){// character is not found
                ans+=s[i];//answer
            }
        }
        return ans;// return the final answer

    }
};